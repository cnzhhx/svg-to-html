# ============================================================
# svg-to-html 服务配置
# 所有变量均为可选，使用默认值可直接启动
# 使用方式：复制为 .env 后按需修改，然后用 dotenv 加载或直接 export
# ============================================================

# ─── 服务基础 ───────────────────────────────────────────────
# HTTP 监听端口
PORT=80
# 工作区根目录，session 产物（SVG/HTML/PNG）均存放于此
WORKSPACE=./workspace
# 运行环境；production 时 MAX_CONCURRENT_AGENTS 默认为 1
NODE_ENV=development

# ─── 浏览器路径（用于截图 / 渲染 / CDP） ─────────────────────
# 按优先级从高到低，找到第一个可执行路径即使用
# Chromium / Edge 可执行文件绝对路径
CHROMIUM_PATH=
# Google Chrome 可执行文件路径
CHROME_PATH=
# 其他 Chromium 内核浏览器路径
BROWSER_PATH=

# ─── CDP（Chrome DevTools Protocol）超时 ─────────────────────
# 单个 CDP 命令最长等待时间（毫秒）
CDP_SEND_TIMEOUT_MS=120000
# 浏览器进程 ready 等待超时（毫秒）
CDP_READY_TIMEOUT_MS=60000

# ─── Agent 并发与执行控制 ─────────────────────────────────────
# 同时运行的 session 数量
MAX_CONCURRENT_AGENTS=2
# 单个 session 内同时运行的模块 agent 数量
MAX_PARALLEL_MODULE_AGENTS=5

# ─── Agent 验证 / 回滚阈值 ───────────────────────────────────
# diffRatio 反弹超过此值时自动回滚到最佳状态
AGENT_VERIFY_ROLLBACK_THRESHOLD=0.005

# ─── Diff / 像素对比 ─────────────────────────────────────────
# 全页面 diff 合格阈值（0.05 = 5%）
DIFF_RATIO_THRESHOLD=0.05
# 单模块 diff 合格阈值
MODULE_DIFF_RATIO_THRESHOLD=0.05
# 截图缩放倍数（越大越清晰但渲染越慢）
PNG_RASTER_SCALE_MULTIPLIER=2

# ─── 超时配置 ─────────────────────────────────────────────────
# 模块 agent 单次执行最长时间（毫秒，默认 1 小时）
MODULE_AGENT_TIMEOUT_MS=3600000
# 视觉文字识别（OCR / vision LLM）超时（毫秒，默认 5 分钟）
VISION_TEXT_TIMEOUT_MS=300000

# ─── Session 日志限制（控制内存 & SSE 推送体积） ──────────────
# 单条日志最大字符数
SESSION_LOG_MAX_CHARS=12000
# session 日志条目上限（超出后裁剪旧条目）
SESSION_LOG_MAX_ENTRIES=500
# agent 事件输出截断长度
SESSION_AGENT_EVENT_OUTPUT_MAX_CHARS=100
# agent 推理事件截断长度
SESSION_AGENT_REASONING_EVENT_MAX_CHARS=4000
# stdout 日志单条最大字符数
SESSION_AGENT_STDOUT_LOG_CHARS=100
# stdout 日志最大行数
SESSION_AGENT_STDOUT_LOG_LINES=20
# stdout 单行字符上限
SESSION_AGENT_STDOUT_LOG_LINE_CHARS=100
# 模型调用遥测记录条数上限
SESSION_MODEL_TELEMETRY_RECORDS=200
# 事件中命令输出截断长度
SESSION_EVENT_COMMAND_OUTPUT_CHARS=100

# ─── 前端缓存 ─────────────────────────────────────────────────
# 是否把 session 产物缓存到浏览器 localStorage（1 = 开启，默认关闭）
SESSION_LOCAL_STORAGE_ENABLED=0

# ─── Session 删除控制 ─────────────────────────────────────────
# 是否禁用 session 删除功能（1 = 禁用，前后端同时生效）
SESSION_DELETE_DISABLED=1

# ─── Session 聊天修复控制 ─────────────────────────────────────
# 是否禁用 session 聊天修复功能（1 = 禁用，默认禁用；设为 0 可开启）
SESSION_CHAT_DISABLED=1

# ─── LLM 推理深度 ────────────────────────────────────────────
# 可选值：none / minimal / low / medium / high / xhigh
# 默认推理深度（对所有角色生效的兜底值）
DEFAULT_AGENT_REASONING_EFFORT=high
# 模块 agent 推理深度
AGENT_UNIT_REASONING_EFFORT=high
SUPPORT_AGENT_REASONING_EFFORT=none

# ─── 模型配置 ────────────────────────────────────────────────
# 模型通过 config/model-provider.json 配置（参考 config/model-provider.example.json）
# 以下环境变量可按角色覆盖 JSON 中的配置
# 角色前缀：TEXT_ / VISION_ / MODULE_AGENT_
#
# 示例（以 TEXT 角色为例）：
# TEXT_MODEL_CONFIG_ID=            # 指向 model-provider.json 中的模型配置 ID
# TEXT_MODEL_API_KEY=              # API Key
# TEXT_MODEL_BASE_URL=             # API 端点 URL
# TEXT_MODEL_ID=                   # 模型名称（如 gpt-4o）
# TEXT_MODEL_RUNTIME=opencode      # 运行时（当前仅支持 opencode）
# TEXT_MODEL_WIRE_API=chat-completions  # 协议格式（chat-completions / responses）
# TEXT_MODEL_REASONING_EFFORT=     # 覆盖该角色的推理深度
# TEXT_MODEL_MAX_OUTPUT_TOKENS=    # 最大输出 token 数
# TEXT_MODEL_CONTEXT_WINDOW=       # 上下文窗口大小
# TEXT_MODEL_CLI_ID=               # CLI 工具使用的模型标识
# TEXT_MODEL_RUNTIME_TRACE=true    # 是否输出 runtime trace 日志
# TEXT_MODEL_RUNTIME_TRACE_SAMPLE_CHARS=100  # trace 采样字符数
# TEXT_MODEL_PROVIDER_NAME=        # 提供商显示名称
# TEXT_MODEL_THINKING=false        # 是否让 opencode 输出 thinking blocks（otherModel 默认 false，moduleAgent 默认 true）
