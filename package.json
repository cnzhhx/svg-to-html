{
  "name": "svg-to-html-workspace",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:mcp": "pnpm -C backend run build:mcp",
    "build": "pnpm -C frontend build && pnpm -C backend run check",
    "build:frontend": "pnpm -C frontend build",
    "check": "pnpm -C backend run check",
    "dev": "pnpm --parallel --stream --filter @svg-to-html/backend --filter @svg-to-html/frontend run dev",
    "dev:frontend": "pnpm -C frontend dev",
    "doctor": "pnpm -C backend run doctor",
    "lint:frontend": "pnpm -C frontend run lint:types",
    "lint:types": "pnpm -C backend run lint:types",
    "start": "pnpm -C backend start",
    "test": "pnpm -C backend test",
    "task:analyze-session-cost": "pnpm -C backend run task:analyze-session-cost",
    "task:browser-query": "pnpm -C backend run task:browser-query",
    "task:diagnose-module-alignment": "pnpm -C backend run task:diagnose-module-alignment",
    "task:export-svg-node-asset": "pnpm -C backend run task:export-svg-node-asset",
    "task:extract-module-text": "pnpm -C backend run task:extract-module-text",
    "task:generate": "pnpm -C backend run task:generate",
    "task:inspect-module-svg": "pnpm -C backend run task:inspect-module-svg",
    "task:resolve-container-layout": "pnpm -C backend run task:resolve-container-layout",
    "task:split-svg-modules": "pnpm -C backend run task:split-svg-modules",
    "task:verify": "pnpm -C backend run task:verify",
    "task:verify-module": "pnpm -C backend run task:verify-module",
    "task:verify-module-framework": "pnpm -C backend run task:verify-module-framework"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
